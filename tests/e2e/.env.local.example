# Copy the values into  ../../.env.local  (repo root) so the E2E harness can
# mint free/pro sessions via the Supabase admin API (no passwords typed).
# Source: Supabase dashboard → Project Settings → API, or Vercel env.

NEXT_PUBLIC_SUPABASE_URL=https://sequvmxgtmbirnixeril.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=__anon_key__
SUPABASE_SERVICE_ROLE_KEY=__service_role_key__   # REQUIRED to provision test users + set tiers

# Optional overrides
# E2E_BASE_URL=http://localhost:3000   # or a preview URL (skips auto dev server)
# E2E_WORKERS=4
